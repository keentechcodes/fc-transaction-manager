{
	"name": "fc-transaction-manager",
	"scripts": {
		"dev": "concurrently \"bun run dev:api\" \"bun run dev:ui\"",
		"dev:api": "bun --hot run src/backend/index.ts",
		"dev:ui": "cd src/frontend && bun run dev",
		"check": "biome check .",
		"format": "biome check --write ."
	},
	"dependencies": {
		"papaparse": "^5.5.0",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/papaparse": "^5.3.0",
		"concurrently": "^9.0.0"
	}
}
